# Dongle-Konfiguration
DONGLE_IP=192.168.10.113
DONGLE_PORT=8484
DONGLE_SN=UR015K6052540222

# MPPT-Zuordnung (kommasepariert)
# MPPT 1 = Ost (14 Module, 6,23 kWp)
# MPPT 2+3 = West (21 Module, 9,345 kWp)
MPPT_EAST=1
MPPT_WEST=2,3

# Anlagenparameter (Trina Solar Vertex S+ TSM-NEG9RC.27, 445W)
PV_TOTAL_KWP=15.575
PV_EAST_KWP=6.23
PV_WEST_KWP=9.345

# Polling-Intervall (Sekunden)
POLL_INTERVAL=30

# Datenbank
DATABASE_PATH=/app/data/solarpilot.db

# Pushover (iOS Push-Benachrichtigungen)
# Registrierung: https://pushover.net
PUSHOVER_APP_TOKEN=your_app_token_here
PUSHOVER_USER_KEY=your_user_key_here

# Logging
LOG_LEVEL=INFO
